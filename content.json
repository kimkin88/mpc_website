  "about": {
    "heading": "Why MPC",
    "statement": "Expensive campaigns come and go. **Great images of them never do.** We give ultra-premium outdoor media a second life - as photography that stands alone.",
    "paragraphs": [
      "Media Photography Company specialises in capturing high-quality images of Out of Home advertising campaigns, across every environment and format - from Piccadilly's screens to painted walls in Shoreditch.",
      "With clients spending more than ever on creative outdoor marketing, the demand for ultra-premium imagery has never been higher. Our work delights clients, proves the value of their spend, and becomes an invaluable part of internal communications and marketing material.",
      "We shoot at different times of day, from unexpected angles, folding the movement and energy of the street into every frame - so the result is not just a record, but a graphic, dynamic image in its own right."
    ]
  },
  "process": {
    "heading": "How We Work",
    "steps": [
      {
        "title": "Planning",
        "text": "Deep knowledge of the OOH market and how campaigns are delivered puts us in a unique position to plan the perfect capture - sites, sightlines, light and timing.",
        "img": "/media/How We Work/Planning.webp"
      },
      {
        "title": "Capturing",
        "text": "Full location shoots at various times of day, using a variety of angles and composition. We capture the ad in-situ and the impact it has on the world around it.",
        "img": "/media/How We Work/Capturing.webp"
      },
      {
        "title": "Retouching",
        "text": "Our in-house retouchers spend considerable time in post-production, finishing every frame to the highest professional standard.",
        "img": "/media/How We Work/Retouching.webp"
      },
      {
        "title": "Delivering",
        "text": "High-quality, full-resolution stills and film on completion - ready for reviews, decks, socials and the archive.",
        "img": "/media/How We Work/Delivery.webp"
      }
    ]
  },
