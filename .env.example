# Required in production — change from the default before deploying
ADMIN_KEY=your-secure-password-here

# Required: all /media/* assets are served from Wasabi
REGION=eu-west-1
BUCKET_NAME=your-bucket-name
ACCESS_KEY=your-wasabi-access-key
SECRET_ACCESS_KEY=your-wasabi-secret-access-key
# WASABI_ENDPOINT=https://s3.eu-west-1.wasabisys.com

# Required: admin content is stored in Supabase (not local content.json)
# Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set automatically by most hosts (Render, Railway, Fly, Vercel, etc.)
# PORT=3000

# Optional: force Wasabi redirects instead of proxying media bytes
# (Vercel always redirects — serverless cannot stream large files)
# MEDIA_MODE=redirect
